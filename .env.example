# Root environment template for the FPL clone monorepo.
# Copy this file to `.env` and adjust values as needed.

# API server port
PORT=4000

# SQLite database file used by the API sync and server
DB_PATH=~/fun-fpl/apps/api/data/fpl.sqlite

# Directory where downloaded player and team JPEG assets are stored
ASSETS_DIR=~/fun-fpl/apps/api/data/assets

# Public FPL API base URL
FPL_BASE_URL=https://fantasy.premierleague.com/api

# FPL website origin used for authenticated My Team session login
FPL_SITE_URL=https://fantasy.premierleague.com

# Minimum interval between outbound FPL requests in milliseconds
FPL_MIN_REQUEST_INTERVAL_MS=3000

# Required to encrypt locally stored FPL email/password credentials for My Team sync
FPL_AUTH_SECRET=change-me

# Frontend API base URL
# Optional: leave unset to use the current site origin + /api.
# Set this only when you explicitly want the frontend to call a different API host.

# Comma-separated hostnames Vite should allow in dev mode.
# Example: VITE_ALLOWED_HOSTS=host.example,another-host.example
