{
  "name": "fpl-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev -w @fpl/api\" \"npm run dev -w @fpl/web\"",
    "dev:api": "npm run dev -w @fpl/api",
    "dev:web": "npm run dev -w @fpl/web",
    "sync": "npm run sync -w @fpl/api --",
    "test": "npm run test --workspaces",
    "test:watch": "npm run test:watch --workspaces"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.2"
  }
}
